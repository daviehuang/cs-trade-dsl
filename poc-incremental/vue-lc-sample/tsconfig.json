{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@udsl/ui-kit-core": ["../ui-kit-core/src/index.ts"],
      "@udsl/ui-kit-vue": ["../ui-kit-vue/src/index.ts"],
      "vue": ["node_modules/vue"]
    }
  },
  "include": ["src", "../ui-kit-core/src", "../ui-kit-vue/src"]
}
